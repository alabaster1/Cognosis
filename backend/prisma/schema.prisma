generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  walletAddress       String               @unique
  walletType          String               @default("cardano")
  username            String?              @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lastLoginAt         DateTime?
  role                String               @default("user")
  agentInteractions   AgentInteraction[]
  baselineProfile     BaselineProfile?
  bayesianPriors      BayesianPrior[]
  commitments         Commitment[]
  experimentInstances ExperimentInstance[]
  experiments         ExperimentSession[]
  experimentTemplates ExperimentTemplate[]
  performanceHistory  PerformanceHistory[]
  responses           Response[]
  telepathyMatches    TelepathyMatch[]
  achievements        UserAchievement[]
  profile             UserProfile?
  streak              UserStreak?

  @@index([walletAddress])
}

model UserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  displayName      String?
  bio              String?
  avatarUrl        String?
  totalExperiments Int      @default(0)
  totalScore       Float    @default(0)
  averageScore     Float    @default(0)
  rank             Int?
  notifications    Boolean  @default(true)
  publicProfile    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExperimentSession {
  id                String             @id @default(uuid())
  userId            String
  experimentType    String
  experimentId      String
  startedAt         DateTime           @default(now())
  completedAt       DateTime?
  status            String             @default("in_progress")
  targetHash        String?
  targetMetadata    Json?
  finalScore        Float?
  agentInteractions AgentInteraction[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses         Response[]

  @@index([userId])
  @@index([experimentType])
  @@index([status])
}

model Response {
  id                 String            @id @default(uuid())
  sessionId          String
  userId             String
  responseType       String
  responseData       Json
  encryptedBlob      String?
  ipfsCid            String?
  submittedAt        DateTime          @default(now())
  aiScore            Float?
  aiScoreBreakdown   Json?
  scoredAt           DateTime?
  blindingVerified   Boolean           @default(false)
  engagementRank     String?
  engagementScore    Float?
  scientificMethod   String?
  scientificScore    Float?
  scientificScoredAt DateTime?
  scorerVersion      String?
  commitment         Commitment?
  session            ExperimentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([ipfsCid])
}

model Commitment {
  id                String    @id @default(uuid())
  responseId        String?   @unique
  userId            String
  commitmentHash    String    @unique
  nonce             String
  metadataHash      String    @default("")
  commitTxId        String?
  commitBlockHeight Int?
  commitTimestamp   DateTime?
  revealed          Boolean   @default(false)
  revealTxId        String?
  revealBlockHeight Int?
  revealTimestamp   DateTime?
  cid               String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  data              Json?
  experimentType    String?
  blockchainTxHash  String?
  cardanoSessionId  String?   @unique
  metadata          Json?
  psyRewardAmount   BigInt?
  revealAt          DateTime?
  rewardTxHash      String?
  score             Float?
  scoredAt          DateTime?
  scriptAddress     String?
  stakeLovelace     BigInt?
  status            String    @default("pending")
  walletAddress     String?
  response          Response? @relation(fields: [responseId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([commitmentHash])
  @@index([userId])
  @@index([revealed])
  @@index([status])
  @@index([cardanoSessionId])
}

model AnalyticsEvent {
  id           String   @id @default(uuid())
  eventType    String
  userId       String?
  eventData    Json
  metadata     Json?
  responseTime Int?
  success      Boolean  @default(true)
  errorMessage String?
  timestamp    DateTime @default(now())

  @@index([eventType])
  @@index([timestamp])
  @@index([userId])
}

model Leaderboard {
  id               String    @id @default(uuid())
  userId           String
  walletAddress    String
  username         String?
  overallRank      Int
  overallScore     Float
  experimentType   String?
  totalExperiments Int
  averageScore     Float
  bestScore        Float
  period           String    @default("all_time")
  periodStart      DateTime?
  periodEnd        DateTime?
  updatedAt        DateTime  @updatedAt

  @@unique([userId, experimentType, period])
  @@index([overallRank])
  @@index([experimentType])
}

model SystemMetrics {
  id               String   @id @default(uuid())
  totalUsers       Int      @default(0)
  activeUsers      Int      @default(0)
  totalExperiments Int      @default(0)
  totalCommits     Int      @default(0)
  totalReveals     Int      @default(0)
  avgResponseTime  Float?
  errorRate        Float?
  gasUsed          String?
  dustBalance      String?
  timestamp        DateTime @default(now())

  @@index([timestamp])
}

model Achievement {
  id               String            @id @default(uuid())
  key              String            @unique
  name             String
  description      String
  category         String
  tier             String            @default("bronze")
  requirement      Json
  points           Int               @default(10)
  icon             String?
  totalUnlocked    Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]

  @@index([category])
  @@index([tier])
}

model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  progress      Float       @default(100)
  notified      Boolean     @default(false)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@index([unlockedAt])
}

model UserStreak {
  id               String    @id @default(uuid())
  userId           String    @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  streakStartDate  DateTime?
  totalDaysActive  Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentStreak])
  @@index([longestStreak])
}

model PerformanceHistory {
  id             String   @id @default(uuid())
  userId         String
  experimentType String
  score          Float
  accuracy       Float?
  baselineScore  Float?
  delta          Float?
  pValue         Float?
  zScore         Float?
  experimentId   String?
  metadata       Json?
  recordedAt     DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, experimentType])
  @@index([userId, recordedAt])
  @@index([experimentType])
}

model BayesianPrior {
  id                String   @id @default(uuid())
  userId            String
  experimentType    String
  priorMean         Float    @default(0.5)
  priorVariance     Float    @default(0.1)
  posteriorMean     Float    @default(0.5)
  posteriorVariance Float    @default(0.1)
  sampleSize        Int      @default(0)
  lastUpdated       DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, experimentType])
  @@index([userId])
}

model Agent {
  id                String             @id @default(uuid())
  name              String             @unique
  displayName       String
  description       String?
  model             String
  systemPrompt      String
  config            Json?
  guardrails        Json?
  status            String             @default("active")
  version           String             @default("1.0.0")
  totalInteractions Int                @default(0)
  totalTokens       Int                @default(0)
  averageLatency    Float?
  successRate       Float?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  createdBy         String?
  evaluations       AgentEvaluation[]
  interactions      AgentInteraction[]
  workflows         WorkflowStep[]

  @@index([name])
  @@index([status])
}

model AgentInteraction {
  id               String             @id @default(uuid())
  sessionId        String?
  agentId          String
  userId           String?
  messageType      String
  role             String
  content          String
  metadata         Json?
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?
  successful       Boolean            @default(true)
  guardrailsPassed Boolean            @default(true)
  guardrailFlags   Json?
  timestamp        DateTime           @default(now())
  agent            Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  session          ExperimentSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user             User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([agentId])
  @@index([userId])
  @@index([timestamp])
}

model AgentEvaluation {
  id          String   @id @default(uuid())
  agentId     String
  evalType    String
  dataset     String?
  score       Float
  passed      Boolean
  threshold   Float
  testCases   Int
  passedCases Int
  details     Json?
  suggestions Json?
  evaluatedAt DateTime @default(now())
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([evalType])
  @@index([passed])
}

model ExperimentTemplate {
  id                String               @id @default(uuid())
  name              String
  slug              String               @unique
  description       String
  category          String
  difficulty        String               @default("beginner")
  estimatedDuration Int?
  guardrails        Json?
  requiresConsent   Boolean              @default(true)
  minAge            Int                  @default(18)
  isPublic          Boolean              @default(false)
  isPremium         Boolean              @default(false)
  requiredRole      String               @default("participant")
  usageCount        Int                  @default(0)
  averageRating     Float?
  averageCompletion Float?
  createdBy         String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  instances         ExperimentInstance[]
  creator           User                 @relation(fields: [createdBy], references: [id])
  workflowSteps     WorkflowStep[]

  @@index([slug])
  @@index([category])
  @@index([isPublic])
  @@index([createdBy])
}

model WorkflowStep {
  id              String             @id @default(uuid())
  templateId      String
  order           Int
  stepType        String
  name            String
  description     String?
  agentId         String?
  config          Json?
  requiredData    Json?
  outputData      Json?
  validationRules Json?
  canSkip         Boolean            @default(false)
  requiresReview  Boolean            @default(false)
  agent           Agent?             @relation(fields: [agentId], references: [id])
  template        ExperimentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
  @@index([templateId])
  @@index([agentId])
}

model ExperimentInstance {
  id             String             @id @default(uuid())
  templateId     String
  userId         String
  status         String             @default("started")
  currentStep    Int                @default(0)
  collectedData  Json?
  results        Json?
  startedAt      DateTime           @default(now())
  completedAt    DateTime?
  duration       Int?
  completionRate Float?
  userRating     Int?
  userFeedback   String?
  template       ExperimentTemplate @relation(fields: [templateId], references: [id])
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([userId])
  @@index([status])
}

model TelepathySession {
  id                  String    @id @default(uuid())
  senderId            String
  receiverId          String?
  status              String    @default("awaiting_receiver")
  targetCID           String?
  targetImageUrl      String?
  targetDescription   String?
  distractorCIDs      String[]
  distractorUrls      String[]
  senderTags          String[]
  senderTagsHash      String?
  senderSalt          String?
  senderViewedAt      DateTime?
  senderSubmittedAt   DateTime?
  delayMinutes        Int       @default(30)
  delayStartedAt      DateTime?
  delayEndsAt         DateTime?
  receiverTags        String[]
  receiverChoice      Int?
  receiverChoiceCID   String?
  receiverSubmittedAt DateTime?
  commitmentHash      String?
  commitTxId          String?
  revealTxId          String?
  blockchainMode      String    @default("guest")
  clipSimilarity      Float?
  psiCoefficient      Float?
  tagOverlapScore     Float?
  overallScore        Float?
  scoringDetails      Json?
  experimentType      String    @default("telepathy-ghost")
  inviteCode          String?   @unique
  matchId             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  expiresAt           DateTime?

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([inviteCode])
  @@index([createdAt])
}

model TelepathyMatch {
  id             String    @id @default(uuid())
  userId         String
  role           String
  status         String    @default("waiting")
  preferredDelay Int       @default(30)
  matchedWith    String?
  sessionId      String?
  queuedAt       DateTime  @default(now())
  matchedAt      DateTime?
  expiresAt      DateTime
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([role])
  @@index([userId])
  @@index([queuedAt])
}

model BaselineProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  ageRange             String
  gender               String?
  handedness           String
  timezone             String?
  meditationExperience Int      @default(0)
  beliefScale          Int      @default(5)
  psiTraining          String   @default("None")
  geomagneticIndex     Float?
  lunarPhase           String?
  dataVersion          String   @default("1.0")
  encryptedData        String?
  commitmentHash       String?
  createdAt            DateTime @default(now())
  expiresAt            DateTime
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SessionCalibration {
  id                   String   @id @default(uuid())
  userId               String
  sessionId            String?
  experimentType       String
  sleepHours           Float?
  caffeineIntake       String?
  substancesUsed       String?
  moodState            Int      @default(5)
  stressLevel          Int      @default(5)
  focusLevel           Int      @default(5)
  timePressure         Boolean  @default(false)
  outcomeExpectation   Int?     @default(5)
  localTime            DateTime @default(now())
  deviceLight          Float?
  heartRate            Int?
  geomagneticIndex     Float?
  lunarPhase           String?
  attentionCheckPassed Boolean  @default(true)
  dataVersion          String   @default("1.0")
  encryptedData        String?
  commitmentHash       String?
  skipped              Boolean  @default(false)
  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([experimentType])
  @@index([createdAt])
}

model PostExperimentFeedback {
  id                   String   @id @default(uuid())
  userId               String
  sessionId            String?
  experimentType       String
  difficulty           Int      @default(5)
  confidence           Int      @default(5)
  phenomenology        String[]
  comments             String?
  tokensEarned         Int      @default(0)
  bonusTokens          Int      @default(0)
  tokenReason          String?
  achievementsUnlocked String[]
  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([experimentType])
}
